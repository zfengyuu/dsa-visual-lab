{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@dsa-visual-lab/shared-types": ["packages/shared-types/src/index.ts"],
      "@dsa-visual-lab/lessons": ["packages/lessons/src/index.ts"],
      "@dsa-visual-lab/visualizer-core": ["packages/visualizer-core/src/index.ts"],
      "@dsa-visual-lab/code-runner": ["packages/code-runner/src/index.ts"],
      "@dsa-visual-lab/ui": ["packages/ui/src/index.ts"]
    }
  }
}
